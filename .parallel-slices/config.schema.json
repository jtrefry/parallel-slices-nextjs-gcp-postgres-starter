{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Parallel Slices project configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "sliceCompilation",
    "packageManager",
    "protectedBranches",
    "branchPolicy",
    "steps",
    "pipelines",
    "entrypoints"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "const": 5 },
    "workspaceMode": { "type": "string", "minLength": 1 },
    "sliceCompilation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sizingStrategy"],
      "properties": {
        "sizingStrategy": {
          "enum": ["isolation-first", "throughput-balanced"]
        }
      }
    },
    "packageManager": {
      "enum": ["auto", "npm", "pnpm", "yarn", "bun"]
    },
    "protectedBranches": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "branchPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pattern", "example"],
      "properties": {
        "pattern": { "type": "string", "minLength": 1 },
        "example": { "type": "string", "minLength": 1 },
        "automationPatterns": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "steps": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "pattern": "^[a-z][a-z0-9-]*$" },
      "additionalProperties": { "$ref": "#/$defs/step" }
    },
    "pipelines": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "pattern": "^[a-z][a-z0-9-]*$" },
      "additionalProperties": { "$ref": "#/$defs/pipeline" }
    },
    "entrypoints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generatedBaseline", "preCommit", "prePush", "ci", "loop"],
      "properties": {
        "generatedBaseline": { "$ref": "#/$defs/pipelineEntrypoint" },
        "preCommit": { "$ref": "#/$defs/pipelineEntrypoint" },
        "prePush": { "$ref": "#/$defs/pipelineEntrypoint" },
        "ci": { "$ref": "#/$defs/pipelineEntrypoint" },
        "loop": {
          "type": "object",
          "additionalProperties": false,
          "required": ["pipelineFrom"],
          "properties": {
            "pipelineFrom": { "const": "scopeManifest" }
          }
        }
      }
    }
  },
  "$defs": {
    "stepId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "capability": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9:-]*$"
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "runner", "scripts", "timeoutSeconds", "provides"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 100 },
        "runner": { "const": "package-script" },
        "scripts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9:_-]+$"
          }
        },
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3600
        },
        "provides": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/capability" }
        }
      }
    },
    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "steps": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/stepId" }
        },
        "extends": { "$ref": "#/$defs/stepId" },
        "append": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/stepId" }
        }
      },
      "oneOf": [
        {
          "required": ["steps"],
          "not": {
            "anyOf": [{ "required": ["extends"] }, { "required": ["append"] }]
          }
        },
        {
          "required": ["extends"],
          "not": { "required": ["steps"] }
        }
      ]
    },
    "pipelineEntrypoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pipeline"],
      "properties": {
        "pipeline": { "$ref": "#/$defs/stepId" }
      }
    }
  }
}
